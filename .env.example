PORT=4000
HORIZON_URL=https://horizon-testnet.stellar.org
NETWORK_PASSPHRASE=Test SDF Network ; September 2015
CORS_ORIGIN=http://localhost:3000,exp://localhost:8081
DATABASE_URL=postgresql://user:password@localhost:5432/globewallet
REDIS_URL=redis://localhost:6379
# Used to sign and verify JWT access tokens. Generate with e.g.
# `openssl rand -hex 32`.
JWT_SECRET=change_me_in_production

# DEPRECATED — used only to authenticate POST /api/v1/auth/login to obtain
# JWT tokens. Required to call POST /api/v1/wallet/send and
# POST /api/v1/wallet/keypair (via JWT). Sent as the `x-api-key` request
# header. Generate with e.g. `openssl rand -hex 32`.
API_KEY=change_me_in_production

# Serializes concurrent /wallet/send calls for the same source account.
# "in-process" (default) only works within a single running instance of
# this API. If you run more than one instance (multiple pods/processes
# behind a load balancer), set this to "redis" so all instances share one
# lock via REDIS_URL above — see docs/concurrency.md.
LOCK_BACKEND=in-process

# Soroban RPC — separate protocol/endpoint from Horizon above (simulate/
# send/getTransaction vs. classic submitTransaction), so it gets its own
# client config. Defaults already point at testnet.
SOROBAN_RPC_URL=https://soroban-testnet.stellar.org
SOROBAN_NETWORK_PASSPHRASE=Test SDF Network ; September 2015

# Deployed globe-wallet contract ID (Orbit-Wal/contract, contracts/globe-wallet).
# Optional — GET/POST /api/v1/contract/wallet/* return 503 until this is set.
# The value below is a real contract deployed to testnet while validating
# this integration (see the PR that introduced it for how/why); it has one
# demo user (GBLIQBXTAF3O3YINCRDR5O7H47QHHW5GFOYN4HAD6IKOSWD4LWKWWPHP) with
# an XLM asset and a 10,000,000-stroop daily spend limit already set, so you
# can `cp .env.example .env && npm run dev` and immediately curl a live
# GET /api/v1/contract/wallet/GBLIQBXTAF3O3YINCRDR5O7H47QHHW5GFOYN4HAD6IKOSWD4LWKWWPHP/assets
# against real testnet without deploying anything yourself.
GLOBE_WALLET_CONTRACT_ID=CBGLPMNSM4FWMIZ6FFBSRN7FNVCHCI2SLZNODA27LEOXFPLWNYEAEP3K
