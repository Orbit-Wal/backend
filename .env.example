PORT=4000
HORIZON_URL=https://horizon-testnet.stellar.org
NETWORK_PASSPHRASE=Test SDF Network ; September 2015
CORS_ORIGIN=http://localhost:3000,exp://localhost:8081
DATABASE_URL=postgresql://user:password@localhost:5432/globewallet
REDIS_URL=redis://localhost:6379
# Used to sign and verify JWT access tokens. Generate with e.g.
# `openssl rand -hex 32`.
JWT_SECRET=change_me_in_production

# DEPRECATED — used only to authenticate POST /api/v1/auth/login to obtain
# JWT tokens. Required to call POST /api/v1/wallet/send and
# POST /api/v1/wallet/keypair (via JWT). Sent as the `x-api-key` request
# header. Generate with e.g. `openssl rand -hex 32`.
API_KEY=change_me_in_production
